<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Zone Name Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_zone_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/no_zone_selected" />

                <Button
                    android:id="@+id/btn_change_zone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/change_zone"
                    android:textSize="12sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/orange"
                    android:textColor="@color/orange" />
            </LinearLayout>

            <!-- BIG STATUS CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_status"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/grey_mid"
                android:foreground="?attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_status_main"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/white"
                            android:textSize="48sp"
                            android:fontFamily="sans-serif-black"
                            android:contentDescription="@string/desc_power_status" />

                        <TextView
                            android:id="@+id/tv_status_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/status_waiting"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_bar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:visibility="gone" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Freshness & Confirm -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tv_last_updated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/no_data_yet"
                    android:textSize="13sp"
                    android:textColor="@color/blue_light" />

                <TextView
                    android:id="@+id/tv_confirm_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirmed by 0 farmer(s)"
                    android:textSize="12sp"
                    android:textColor="@color/grey_light" />
            </LinearLayout>

            <!-- Report Buttons -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/report_status_label"
                android:textColor="@color/grey_light"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btn_power_on"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/power_on"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:backgroundTint="@color/green_on"
                    android:textColor="@color/white"
                    android:contentDescription="@string/desc_report_on" />

                <Button
                    android:id="@+id/btn_power_off"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/power_off"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:backgroundTint="@color/red_off"
                    android:textColor="@color/white"
                    android:contentDescription="@string/desc_report_off" />

            </LinearLayout>

            <!-- Confirm Button -->
            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/confirm_status"
                android:textSize="14sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/orange"
                android:textColor="@color/orange"
                android:layout_marginBottom="16dp" />

            <!-- History Link -->
            <TextView
                android:id="@+id/tv_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/view_history"
                android:textColor="@color/blue_light"
                android:textSize="14sp"
                android:padding="8dp"
                android:gravity="center"
                android:layout_marginBottom="72dp" />


        </LinearLayout>
    </ScrollView>

    <!-- FAB for Pump Timer -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/pump_timer"
        android:contentDescription="@string/desc_open_timer"
        app:icon="@drawable/ic_pump"
        app:layout_anchorGravity="bottom|end"
        android:layout_gravity="bottom|end"
        app:backgroundTint="@color/orange" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
