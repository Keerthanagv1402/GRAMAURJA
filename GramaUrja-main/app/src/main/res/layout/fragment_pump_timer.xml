<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pump_timer_title"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pump_timer_subtitle"
            android:textColor="@color/grey_light"
            android:textSize="13sp"
            android:layout_marginBottom="20dp" />

        <!-- Crop Spinner -->
        <TextView
            android:id="@+id/label_crop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/crop_type_label"
            android:textColor="@color/orange"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"
            android:labelFor="@+id/spinner_crop" />

        <Spinner
            android:id="@+id/spinner_crop"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/card_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- Area Input -->
        <TextView
            android:id="@+id/label_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/field_area_label"
            android:textColor="@color/orange"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="6dp"
            android:labelFor="@+id/et_area" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btn_area_minus"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="−"
                android:textSize="22sp"
                android:backgroundTint="@color/card_bg"
                android:textColor="@color/white"
                android:contentDescription="@string/area_minus_desc"
                style="?attr/borderlessButtonStyle" />

            <EditText
                android:id="@+id/et_area"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="1.0"
                android:inputType="numberDecimal"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:background="@color/card_bg"
                android:layout_marginHorizontal="8dp"
                android:autofillHints="none" />

            <Button
                android:id="@+id/btn_area_plus"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="+"
                android:textSize="22sp"
                android:backgroundTint="@color/card_bg"
                android:textColor="@color/white"
                android:contentDescription="@string/area_plus_desc"
                style="?attr/borderlessButtonStyle" />

        </LinearLayout>

        <!-- Recommended Time -->
        <TextView
            android:id="@+id/tv_recommended_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/recommended_time_format"
            android:textColor="@color/blue_light"
            android:textSize="15sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- Countdown Display -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/navy">

            <TextView
                android:id="@+id/tv_countdown"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="00:00"
                android:textColor="@color/yellow_hi"
                android:textSize="56sp"
                android:fontFamily="monospace" />

        </androidx.cardview.widget.CardView>

        <!-- Timer Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_start_timer"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/start_timer"
                android:textSize="16sp"
                android:backgroundTint="@color/green_on"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btn_stop_timer"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/stop_timer"
                android:textSize="16sp"
                android:backgroundTint="@color/red_off"
                android:textColor="@color/white"
                android:enabled="false" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
